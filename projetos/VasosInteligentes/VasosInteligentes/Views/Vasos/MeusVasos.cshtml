@model IEnumerable<VasosInteligentes.Models.Planta>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UmidadeIdealMin)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UmidadeIdealMax)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LuminosidadeIdeal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UltimaLeitura.Temperatura)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UltimaLeitura.Umidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UltimaLeitura.DataLeitura)
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UmidadeIdealMin)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UmidadeIdealMax)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LuminosidadeIdeal)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
