@model IEnumerable<VasosInteligentes.Models.ApplicationUser>

<div class="container mt-4">
    <h2>Gerenciar Usußrios - Vasos Inteligentes</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Novo Usußrio</a>

    <table class="table">
        <thead>
            <tr>
                <th>E-mail</th>
                <th>Aþ§es</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model) {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm" onclick="return confirm('Excluir?')">Remover</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>